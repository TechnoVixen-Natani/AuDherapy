// js/brain.js - The Forensic Data Brain
let db = JSON.parse(localStorage.getItem('audherapy_db')) || [];
let appConfig = JSON.parse(localStorage.getItem('audherapy_config')) || {}; 

// Add these at the very top of brain.js to handle the hardware "brain"
const { Camera } = Capacitor.Plugins;
const { VoiceRecorder } = Capacitor.Plugins;

// This ensures your journal doesn't "leak" data before you hit save
async function captureVideoMemo() {
    const video = await Camera.getPhoto({
        quality: 90,
        resultType: 'uri',
        source: 'CAMERA'
    });
    log('Journal', 'VideoPath', video.webPath, 'Forensic Video Attached');
}

// Initialize Default Config if empty
if (Object.keys(appConfig).length === 0) {
    appConfig = {
        maintenance: [
            {label: '💧 Water', item: 'Water', color: '#4A90E2'}, 
            {label: '🪥 Teeth', item: 'Teeth', color: '#FF3366'},
            {label: '⚖️ Weight', item: 'Weight', color: '#FFD700'}
        ],
        meds: [
            {label: '🌅 Morning', item: 'Morning', color: '#FFD700'}, 
            {label: '🌇 Evening', item: 'Evening', color: '#FF8C00'}, 
            {label: '🌃 Night', item: 'Night', color: '#4A90E2'}
        ],
        medicationLibrary: []
    };
    localStorage.setItem('audherapy_config', JSON.stringify(appConfig));
}

function log(cat, item, val = null, note = "") {
    db.push({ 
        timestamp: Date.now(), 
        date: new Date().toLocaleDateString(), 
        time: new Date().toLocaleTimeString(), 
        category: cat, item: item, value: val, note: note 
    });
    localStorage.setItem('audherapy_db', JSON.stringify(db));
    alert("Logged to Vault!");
}

// Session Security: Check if user is "validated"
function checkAuth() {
    if (sessionStorage.getItem('aud_auth') !== 'true') {
        window.location.href = 'index.html';
    }
}

// --- PROJECT VOIDSTAR: MULTIMEDIA UPGRADES ---

// 1. Voice Memo Recording (Using the Capacitor Plugin)
async function recordVoiceMemo() {
    try {
        const { VoiceRecorder } = Capacitor.Plugins;
        const result = await VoiceRecorder.startRecording();
        alert("Recording Started... Tap again to stop.");
    } catch (e) {
        console.error("Voice Hardware Error:", e);
    }
}

// 2. Video/Photo Memo
async function captureVideoMemo() {
    try {
        const { Camera } = Capacitor.Plugins;
        const result = await Camera.getPhoto({
            quality: 90,
            allowEditing: false,
            resultType: 'uri'
        });
        log('Media', 'VideoMemo', result.webPath, 'Captured forensic video');
    } catch (e) {
        console.error("Camera Hardware Error:", e);
    }
}

// 3. Native File System (For persistent local storage)
async function backupVaultToFile() {
    const { Filesystem } = Capacitor.Plugins;
    const data = localStorage.getItem('audherapy_db');
    await Filesystem.writeFile({
        path: 'audherapy_backup.json',
        data: data,
        directory: 'DOCUMENTS',
        encoding: 'utf8'
    });
    alert("Full Database Backed up to Device Documents!");
}

// Mirror localStorage to a Permanent Native File
async function syncVaultToFile() {
    try {
        const { Filesystem } = Capacitor.Plugins;
        const currentData = localStorage.getItem('audherapy_db');
        
        await Filesystem.writeFile({
            path: 'project_voidstar_backup.json',
            data: currentData,
            directory: 'DOCUMENTS',
            encoding: 'utf8'
        });
        console.log("Forensic Mirror: Success (File Updated)");
    } catch (e) {
        console.error("Mirror Failed: LocalStorage only for now.", e);
    }
}

// Update your existing log function to trigger the mirror
const originalLog = log; 
log = function(cat, item, val, note) {
    originalLog(cat, item, val, note); // Run your current code
    syncVaultToFile();                 // Then save the file backup
};

